# Copy to .env and fill in. NEVER commit the real .env (it holds your secret).

# From the app registration Overview page:
CLIENT_ID=78609b42-4daf-4fb8-b9bf-b8cecf2d6c1f

# Create one under: Manage > Certificates & secrets > New client secret.
# Paste the secret VALUE (not the Secret ID) here.
CLIENT_SECRET=

# "organizations" matches your "Multiple organizations" registration.
# Set to your tenant GUID (a272645c-35ea-469e-bc75-e0bdf29a3c52) to restrict
# login to only your own tenant.
TENANT=organizations

PORT=7070
# Must EXACTLY match a Redirect URI registered under the "Web" platform.
REDIRECT_URI=http://localhost:7070/auth/callback
