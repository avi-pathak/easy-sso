# Copy to .env and fill in. NEVER commit the real .env (it holds your secrets).
# These are the SAME variables as examples/login-webapp (Node) — you can reuse
# the same values / app registrations. Configure Microsoft, Google, or BOTH.

PORT=7070

# ─── Microsoft Entra ID ──────────────────────────────────────────────────────
# From the app registration Overview page:
CLIENT_ID=78609b42-4daf-4fb8-b9bf-b8cecf2d6c1f
# Manage > Certificates & secrets > New client secret — paste the VALUE:
CLIENT_SECRET=
# "organizations" matches a "Multiple organizations" registration. Set to your
# tenant GUID to restrict login to only your own tenant.
TENANT=organizations
# Must EXACTLY match a Redirect URI registered under the "Web" platform.
REDIRECT_URI=http://localhost:7070/auth/callback
# Used only by curl-test.sh (app-only client-credentials grant needs a tenant GUID).
TENANT_GUID=a272645c-35ea-469e-bc75-e0bdf29a3c52

# ─── Google ──────────────────────────────────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# (type: Web application). Add the redirect URI below to "Authorized redirect URIs".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:7070/auth/google/callback
